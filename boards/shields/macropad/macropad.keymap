#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &kp A, &kp B, &kp C   // Row 1: Top Row (Q-R)
            >;
            sensor-bindings = <&inc_dec_kp RBKT LBKT>;
        };
    };
};
