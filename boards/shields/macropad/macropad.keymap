#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
                &studio_unlock // Press Key 1 to unlock Studio
                &kp B          // Key 2
                &kp C          // Key 3
            >;
        };

        extra_layer {
            status = "reserved";
        };
    };
};
