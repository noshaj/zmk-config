#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
                &kp C &kp N5 &kp N9 &kp N4
                &kp D &kp N6 &kp N0 &kp N8
                &kp G &kp N7 &kp MINUS &kp EQUAL
                /* These are your 'B' and 'D' boxes in Studio */
                &kp LBKT &kp RBKT 
            >;
            
            /* This is the magic link: it tells the encoder to 
               trigger the keys assigned to positions 12 and 13 */
            sensor-bindings = <&inc_dec_kp LBKT RBKT>;
        };

        extra_layer {
            status = "reserved";
        };
    };
};
