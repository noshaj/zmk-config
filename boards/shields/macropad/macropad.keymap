#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &kp Q &kp W &kp E &kp R    // Row 1: Top Row (Q-R)
                &kp A &kp S &kp D &kp F    // Row 2: Middle Row (A-F)
                &kp Z &kp X &kp C &kp V    // Row 3: Bottom Row (Z-V)
            >;
            sensor-bindings = <&inc_dec_kp RBKT LBKT>;
        };
    };
};
