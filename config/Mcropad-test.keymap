#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        // Layer 0: Base
        default_layer {
            display-name = "Base";
            bindings = <
                &kp C &kp N5 &kp N9 &kp N4
                &kp D &kp N6 &kp N0 &kp N8
                &mo 1 &kp N7 &kp MINUS &kp EQUAL
            >;
            sensor-bindings = <&inc_dec_kp RBKT LBKT>;
        };

        // Layer 1: Bluetooth
        layer_1 {
            display-name = "BT";
            bindings = <
                &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_CLR
                &mo 2        &trans       &trans       &trans
                &trans       &trans       &trans       &trans
            >;
            sensor-bindings = <&inc_dec_kp LBKT RBKT>;
        };

        // Layer 2: System (Sleep)
        layer_2 {
            display-name = "Sleep";
            bindings = <
                &soft_off &trans &trans &trans
                &trans    &trans &trans &trans
                &mo 3     &trans &trans &trans
            >;
            sensor-bindings = <&inc_dec_kp LBKT RBKT>;
        };

        // Layer 3: Media
        layer_3 {
            display-name = "Media";
            bindings = <
                &kp C_PREV &kp C_PP &kp C_NEXT &trans
                &trans     &trans   &trans     &trans
                &trans     &trans   &trans     &trans
            >;
            sensor-bindings = <&inc_dec_kp LBKT RBKT>;
        };

        extra_layer {
            status = "reserved";
        };
    };
};
